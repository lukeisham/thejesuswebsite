  "query": "SELECT \n                c.id as contact_id, c.name, c.email,\n                m.id as message_id, m.subject, m.body, m.sent_at, m.read_at\n             FROM contacts c \n             JOIN contact_messages m ON c.id = m.contact_id \n             WHERE m.read_at IS NULL",
