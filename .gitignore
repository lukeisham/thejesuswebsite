# Dependencies
node_modules/

# Environment
.env

# Database files
*.db
*.db-journal
*.db-wal
*.db-shm

# User uploads (keep the directory, ignore contents)
public/uploads/*
!public/uploads/.gitkeep

# Logs
*.log
logs/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

