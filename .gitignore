# Dependencies
node_modules/

# Local notes / planning (not for GitHub), except the specific paths
# re-included below, which are tracked and pushed like any other file.
!/setup/
/setup/*
!/setup/SKILLS
!/setup/SKILLS/**
!/setup/Wikipedia algorithm
!/setup/Wikipedia algorithm/**
!/setup/Vibe_coding_rules.md
!/setup/STYLE_GUIDE
!/setup/STYLE_GUIDE/**
!/setup/plan_template.md
/scratchpad.md
/CLAUDE.local.md

# Python build artifacts — placed after the /setup/ re-inclusion block so it
# still wins inside the re-included paths (gitignore: later rules win).
__pycache__/
*.pyc

# Environment
.env

# Database files
*.db
*.db-journal
*.db-wal
*.db-shm

# User uploads (keep the directory, ignore contents)
public/uploads/*
!public/uploads/.gitkeep

# Logs
*.log
logs/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Generated detail pages (rebuilt on deploy via npm run pages).
# Brackets are escaped: unescaped [slug] is a glob character class,
# so the un-ignore patterns silently never matched the template files.
frontend/evidence/single/*.html
!frontend/evidence/single/\[slug\].html
frontend/contextual-essays/*.html
!frontend/contextual-essays/\[slug\].html
!frontend/contextual-essays/index.html
frontend/debate/responses/*.html
!frontend/debate/responses/\[slug\].html
frontend/debate/historiography/*.html
!frontend/debate/historiography/\[slug\].html
!frontend/debate/historiography/index.html
frontend/news-and-blog/blog/*.html
!frontend/news-and-blog/blog/\[slug\].html
!frontend/news-and-blog/blog/index.html
frontend/news-and-blog/news/*.html
!frontend/news-and-blog/news/\[slug\].html
!frontend/news-and-blog/news/index.html
frontend/debate/popular-challenges/*.html
!frontend/debate/popular-challenges/\[slug\].html
frontend/debate/academic-challenges/*.html
!frontend/debate/academic-challenges/\[slug\].html
