# Base URL of the thejesuswebsite JSON API.
#
#   Local development:    http://localhost:3000/api
#   Production / live:    https://www.thejesuswebsite.org/api
#
API_BASE_URL=https://www.thejesuswebsite.org/api

# Port for the Streamable HTTP transport (ignored in --stdio mode).
# Default: 3100
#
PORT=3100
