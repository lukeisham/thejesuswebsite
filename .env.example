# =============================================================================
#   THE JESUS WEBSITE — ENVIRONMENT VARIABLES
#   File:    .env.example
#   Version: 1.0.0
#   Purpose: Template for required environment variables.
#            Copy to .env and fill in real values before running.
#   IMPORTANT: .env is gitignored — never commit it.
# =============================================================================

# --- Admin Authentication ---
# Password for the single admin account. Choose a strong, unique value.
ADMIN_PASSWORD=change-me-to-a-strong-password

# JWT signing secret. Generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-64-char-hex-string

# --- Cookie Security ---
# Set to true in production (behind HTTPS). Keep false for local dev.
COOKIE_SECURE=false

# --- DeepSeek API ---
# API key for AI-powered content generation (snippets, metadata).
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# --- MCP Server ---
# Internal URL for the MCP read-only agent server.
MCP_SERVER_URL=http://127.0.0.1:8001/health
