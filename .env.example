# --- Server Configuration ---
# The port the Rust app_ui binary will bind to
APP_PORT=8080
# Options: development, staging, production
APP_ENV=development
# Your VPS public IP or Domain (e.g., https://api.myapp.com)
BASE_URL=https://thejesuswebsite.org

# --- AI API Configuration (OpenAI) ---
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here
OPENAI_ORG_ID=your_optional_org_id_here

# --- Storage & Database (ChromaDB) ---
# When using docker-compose, the hostname is 'chroma'
CHROMA_URL=http://chroma:8000

# --- GitHub Integration ---
# Required for private crate access or high-rate-limit API calls
GITHUB_TOKEN=your_github_pat_here

# Required if using GitHub OAuth for user login
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# --- Security ---
# IMPORTANT: Generate a random 32-character string for production!
# You can use: openssl rand -base64 32
SESSION_SECRET=Djh6i+8Y9BLmkiFPMlCji8WrFiIc3N64abQ+o4uJZeY=